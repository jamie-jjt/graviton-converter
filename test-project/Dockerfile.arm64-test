# ARM64 build validation - tests if the code compiles on Graviton/ARM64
FROM --platform=linux/arm64 ubuntu:22.04

RUN apt-get update && apt-get install -y gcc build-essential && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY main.c crypto.c simd_ops.c Makefile ./

# Try to compile - if this succeeds, the code is ARM64 compatible
# Note: we override CFLAGS since the Makefile has x86 flags
RUN gcc -O2 -march=armv8-a -o myapp main.c crypto.c simd_ops.c -lm 2>&1 || echo "BUILD FAILED - issues remain"

# If build succeeds, run the binary
CMD ["./myapp"]
